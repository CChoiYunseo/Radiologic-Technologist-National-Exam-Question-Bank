{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "period",
    "subject",
    "field",
    "area",
    "detail",
    "scope_id",
    "learning_objective_id",
    "question_type",
    "competency_type",
    "difficulty",
    "stem",
    "options",
    "answer",
    "explanation",
    "evidence_refs",
    "source_chunks",
    "distractor_strategy",
    "llm_first_check",
    "validation_status",
    "reviewer_agent_results",
    "final_judge",
    "status"
  ],
  "properties": {
    "period": {"type": "string"},
    "subject": {"type": "string"},
    "field": {"type": "string"},
    "area": {"type": "string"},
    "detail": {"type": "string"},
    "scope_id": {"type": "string"},
    "learning_objective_id": {"type": "string"},
    "question_type": {"type": "string"},
    "competency_type": {"type": "string"},
    "difficulty": {"type": "string", "enum": ["하", "중", "상"]},
    "stem": {"type": "string", "minLength": 8},
    "options": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"type": "string", "minLength": 1}
    },
    "answer": {"type": "integer", "minimum": 1, "maximum": 5},
    "explanation": {"type": "string", "minLength": 12},
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rag_input_id"],
        "properties": {
          "rag_input_id": {"type": "string"}
        }
      }
    },
    "source_chunks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rag_input_id"],
        "properties": {
          "rag_input_id": {"type": "string"}
        }
      }
    },
    "distractor_strategy": {"type": "string"},
    "llm_first_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_verdict",
        "checks",
        "notes"
      ],
      "properties": {
        "overall_verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope_alignment",
            "learning_objective_alignment",
            "evidence_grounding",
            "answer_uniqueness",
            "option_quality",
            "explanation_quality",
            "copyright_safety",
            "text_only_policy"
          ],
          "properties": {
            "scope_alignment": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            },
            "learning_objective_alignment": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            },
            "evidence_grounding": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            },
            "answer_uniqueness": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            },
            "option_quality": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            },
            "explanation_quality": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            },
            "copyright_safety": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            },
            "text_only_policy": {
              "type": "object",
              "additionalProperties": false,
              "required": ["verdict", "reason"],
              "properties": {
                "verdict": {"type": "string", "enum": ["pass", "revise", "reject"]},
                "reason": {"type": "string", "minLength": 2}
              }
            }
          }
        },
        "notes": {"type": "string"}
      }
    },
    "validation_status": {"type": "string"},
    "reviewer_agent_results": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "grounding",
        "uniqueness",
        "grammar",
        "copyright"
      ],
      "properties": {
        "scope": {"type": "string"},
        "grounding": {"type": "string"},
        "uniqueness": {"type": "string"},
        "grammar": {"type": "string"},
        "copyright": {"type": "string"}
      }
    },
    "final_judge": {"type": "string"},
    "status": {"type": "string"}
  }
}
