div(class="min-h-full bg-[#dfe5eb] text-slate-950")
    header(class="border-b border-slate-300 bg-white")
        div(class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-3 sm:px-6 lg:flex-row lg:items-center lg:justify-between")
            a(href="/home", class="flex items-center gap-3")
                span(class="flex h-10 w-10 items-center justify-center rounded-sm border border-slate-900 bg-white text-[14px] font-black text-slate-950") RT
                span
                    span(class="block text-[16px] font-black tracking-normal text-slate-950") 방사선사 국가고시 연습
                    span(class="block text-[12px] font-bold text-slate-500") 1·2교시 텍스트형 모의 문제지
            div(class="flex flex-wrap items-center gap-2")
                a(href="/admin/question-candidates", class="flex h-10 items-center rounded-sm border border-slate-300 bg-white px-4 text-[13px] font-black text-slate-700 hover:border-[#2563eb] hover:text-[#2563eb]") 관리자 검수
                button(type="button", (click)="start(subject)", class="h-10 rounded-sm border border-slate-300 bg-white px-4 text-[13px] font-black text-slate-800 hover:bg-slate-50") 새 문제지

    main(class="mx-auto grid max-w-7xl gap-4 px-4 py-4 sm:px-6 xl:grid-cols-[1fr_330px]")
        section(class="min-w-0")
            div(class="mb-3 grid gap-3 rounded-sm border border-slate-300 bg-white p-4 shadow-sm md:grid-cols-[1fr_220px_220px]")
                div
                    div(class="text-[12px] font-black text-slate-500") 모의 문제지
                    h1(class="mt-1 text-[22px] font-black tracking-normal text-slate-950") 방사선사 국가고시 1·2교시 연습
                div(class="rounded-sm border border-slate-200 p-3")
                    div(class="text-[11px] font-black text-slate-500") 선택 과목
                    div(class="mt-1 text-[15px] font-black text-slate-950") {{subject || '전체 과목'}}
                div(class="rounded-sm border border-slate-200 p-3")
                    div(class="text-[11px] font-black text-slate-500") 답안 작성
                    div(class="mt-1 text-[15px] font-black text-slate-950") {{selectedCount()}} / {{questions.length || 0}}

            div(*ngIf="loading", class="flex min-h-[560px] items-center justify-center rounded-sm border border-slate-300 bg-white shadow-sm")
                div(class="text-[14px] font-black text-slate-500") 문제지를 불러오는 중입니다.

            article(*ngIf="!loading && currentQuestion()", class="rounded-sm border border-slate-300 bg-white shadow-sm")
                div(class="border-b border-slate-300 px-5 py-4")
                    div(class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between")
                        div(class="min-w-0")
                            div(class="text-[12px] font-black text-slate-500") {{scopeText(currentQuestion())}}
                            div(class="mt-1 flex flex-wrap items-center gap-2")
                                span(class="text-[24px] font-black tracking-normal text-slate-950") {{currentIndex + 1}}번
                                span(class="rounded-sm border border-slate-300 px-2 py-1 text-[11px] font-black text-slate-600") {{currentQuestion().question_type || '개념형'}}
                                span(class="rounded-sm border border-slate-300 px-2 py-1 text-[11px] font-black text-slate-600") 난이도 {{currentQuestion().difficulty || '중'}}
                        div(class="flex items-center gap-2 text-[12px] font-black text-slate-500")
                            span(*ngIf="!submitted") 미제출
                            span(*ngIf="submitted", class="text-emerald-700") 제출 완료

                div(class="px-5 py-6 sm:px-8")
                    p(class="whitespace-pre-line border-b border-slate-200 pb-6 text-[18px] font-bold leading-8 tracking-normal text-slate-950") {{currentQuestion().stem}}

                    div(class="mt-6 grid gap-3")
                        button(*ngFor="let option of currentQuestion().options", type="button", (click)="selectChoice(option.index)", [ngClass]="optionClass(option)", class="grid min-h-14 grid-cols-[42px_1fr] items-center gap-4 rounded-sm border px-4 py-3 text-left transition")
                            span([ngClass]="optionMarkClass(option)", class="flex h-8 w-8 items-center justify-center rounded-full border text-[13px] font-black") {{option.index}}
                            span(class="text-[15px] font-bold leading-6") {{option.text}}

                    div(*ngIf="submitted && currentResult()", [ngClass]="currentResult().correct ? 'border-emerald-300 bg-emerald-50' : 'border-rose-300 bg-rose-50'", class="mt-6 rounded-sm border p-4")
                        div([ngClass]="currentResult().correct ? 'text-emerald-800' : 'text-rose-800'", class="text-[15px] font-black")
                            span(*ngIf="currentResult().correct") 정답
                            span(*ngIf="!currentResult().correct") 오답
                        div(class="mt-2 text-[13px] font-black text-slate-800") 정답 {{currentResult().correct_answer}}번
                        p(class="mt-3 whitespace-pre-line text-[14px] leading-6 text-slate-700") {{currentResult().explanation}}

                div(class="flex flex-col gap-3 border-t border-slate-300 px-5 py-4 sm:flex-row sm:items-center sm:justify-between")
                    button(type="button", (click)="prev()", [disabled]="currentIndex === 0", class="h-11 rounded-sm border border-slate-300 bg-white px-5 text-[13px] font-black text-slate-700 disabled:cursor-not-allowed disabled:opacity-40 hover:bg-slate-50") 이전 문제
                    div(class="flex flex-wrap gap-2")
                        button(type="button", (click)="next()", [disabled]="currentIndex >= questions.length - 1", class="h-11 rounded-sm border border-slate-300 bg-white px-5 text-[13px] font-black text-slate-700 disabled:cursor-not-allowed disabled:opacity-40 hover:bg-slate-50") 다음 문제
                        button(type="button", (click)="submitExam()", [disabled]="grading || submitted || questions.length === 0", class="h-11 rounded-sm bg-slate-950 px-5 text-[13px] font-black text-white disabled:cursor-not-allowed disabled:opacity-50 hover:bg-[#2563eb]")
                            span(*ngIf="!grading") 답안 제출
                            span(*ngIf="grading") 채점 중

            div(*ngIf="!loading && !currentQuestion()", class="flex min-h-[560px] items-center justify-center rounded-sm border border-slate-300 bg-white p-6 text-center shadow-sm")
                div
                    div(class="text-[18px] font-black text-slate-950") 연습 문제가 없습니다.
                    div(class="mt-2 text-[13px] text-slate-500") 과목을 변경하거나 문제은행 후보를 먼저 준비해주세요.

        aside(class="space-y-4")
            section(class="rounded-sm border border-slate-300 bg-white p-4 shadow-sm")
                div(class="flex items-center justify-between gap-3")
                    h2(class="text-[15px] font-black tracking-normal text-slate-950") OMR 답안지
                    span(class="text-[12px] font-black text-slate-500") {{selectedCount()}} / {{questions.length || 0}}
                div(class="mt-3 h-2 rounded-full bg-slate-100")
                    div([style.width.%]="progress()", class="h-2 rounded-full bg-[#2563eb]")
                div(*ngIf="submitted", class="mt-3 rounded-sm border border-emerald-200 bg-emerald-50 p-3")
                    div(class="text-[12px] font-black text-emerald-800") 채점 결과
                    div(class="mt-1 text-[22px] font-black text-emerald-950") {{resultMessage()}}

                div(class="mt-4 max-h-[520px] space-y-2 overflow-auto pr-1")
                    div(*ngFor="let question of questions; let qi = index", [ngClass]="markerClass(qi)", class="grid grid-cols-[36px_1fr] items-center gap-2 rounded-sm border p-2")
                        button(type="button", (click)="go(qi)", class="h-8 rounded-sm text-[12px] font-black") {{qi + 1}}
                        div(class="grid grid-cols-5 gap-1")
                            button(*ngFor="let option of [1,2,3,4,5]", type="button", (click)="go(qi); selectChoice(option)", [disabled]="submitted", [ngClass]="sheetBubbleClass(question, option)", class="h-7 rounded-full border text-[11px] font-black disabled:cursor-default") {{option}}

            section(class="rounded-sm border border-slate-300 bg-white p-4 shadow-sm")
                h2(class="text-[15px] font-black tracking-normal text-slate-950") 과목 선택
                div(class="mt-3 grid gap-2")
                    button(type="button", (click)="start('')", [ngClass]="subject === '' ? 'border-slate-950 bg-slate-950 text-white' : 'border-slate-300 bg-white text-slate-700 hover:bg-slate-50'", class="h-10 rounded-sm border px-3 text-left text-[13px] font-black") 전체 과목
                    button(*ngFor="let row of summary.subjects", type="button", (click)="start(row.subject)", [ngClass]="subject === row.subject ? 'border-slate-950 bg-slate-950 text-white' : 'border-slate-300 bg-white text-slate-700 hover:bg-slate-50'", class="flex h-10 items-center justify-between rounded-sm border px-3 text-left text-[13px] font-black")
                        span {{row.subject}}
                        span(class="text-[11px] opacity-70") {{row.count}}
